CHECKMARX_DSCAN_DATA_SOURCE=mock

# Optional for mock mode if you do not want to pass job_url explicitly.
# JENKINS_JOB_URL=http://jenkins.example.com/job/folder/job/project/view/change-requests

# Per-tool data source overrides. Set any of these to mock or live to override
# CHECKMARX_DSCAN_DATA_SOURCE for that tool only. This is useful when you want
# to demo Jenkins and SonarQube from bundled fixtures while keeping Checkmarx
# pointed at a real tenant.
# CHECKMARX_DSCAN_DATA_SOURCE_CHECKMARX=live
# CHECKMARX_DSCAN_DATA_SOURCE_JENKINS=mock
# CHECKMARX_DSCAN_DATA_SOURCE_SONAR=mock

# Switch to live mode only when you want to call real systems.
# CHECKMARX_DSCAN_DATA_SOURCE=live
# CHECKMARX_BASE_URL=https://us.ast.checkmarx.net
# CHECKMARX_API_TOKEN=replace_me
# JENKINS_USERNAME=replace_me
# JENKINS_API_TOKEN=replace_me
# JENKINS_JOB_URL=http://jenkins.example.com/job/folder/job/project/job/release_1/
# SONAR_BASE_URL=http://sonar.example.com
# SONAR_TOKEN=replace_me